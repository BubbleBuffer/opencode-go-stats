{
  "name": "opencode-go-stats",
  "version": "1.2.1",
  "description": "Browser extension and userscript for opencode.ai workspace usage analytics",
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BubbleBuffer/opencode-go-stats"
  },
  "private": true,
  "scripts": {
    "build": "node build.js",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "npm run build && cd dist/extension && zip -r ../../extension.zip manifest.json content.js"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "chart.js": "^4.4.0"
  }
}
